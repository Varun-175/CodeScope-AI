# ==========================================================
# CodeScope AI - .gitignore
# ==========================================================

# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# ==========================================================
# Virtual Environments
# ==========================================================
.venv/
venv/
env/
ENV/

# ==========================================================
# Python Build & Distribution
# ==========================================================
build/
dist/
site/
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/

# ==========================================================
# Python Caches
# ==========================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# ==========================================================
# Logs
# ==========================================================
*.log
logs/
log.txt

# ==========================================================
# Environment Variables
# ==========================================================
.env
.env.*
!.env.example

# ==========================================================
# Secrets & Local Configuration
# ==========================================================
backend/app/data/settings.json
backend/app/data/settings.local.json
backend/app/data/*.secret.json
backend/app/data/*.token.json

# Keep only template files
!backend/app/data/settings.template.json

# ==========================================================
# Vector Databases
# ==========================================================
chroma/
chromadb/
vector_store/
vector_db/
*.faiss

# ==========================================================
# Databases
# ==========================================================
*.db
*.sqlite
*.sqlite3

# ==========================================================
# Temporary Files
# ==========================================================
tmp/
temp/
*.tmp
*.temp
*.bak

# ==========================================================
# Git Cloned Repositories
# ==========================================================
repositories/
repos/
cloned_repos/
analysis_cache/

# ==========================================================
# Streamlit
# ==========================================================
.streamlit/

# ==========================================================
# FastAPI
# ==========================================================
.fastapi/

# ==========================================================
# Node.js
# ==========================================================
node_modules/
frontend/node_modules/

# ==========================================================
# React / Vite
# ==========================================================
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/coverage/

# ==========================================================
# Package Managers
# ==========================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# IDEs
# ==========================================================
.vscode/
.idea/
*.iml

# ==========================================================
# Operating System Files
# ==========================================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Jupyter
# ==========================================================
.ipynb_checkpoints/

# ==========================================================
# AI Models
# ==========================================================
models/
weights/
checkpoints/
*.ckpt
*.pt
*.pth
*.bin
*.safetensors
*.gguf

# ==========================================================
# Ollama
# ==========================================================
ollama_models/

# ==========================================================
# Generated Reports
# ==========================================================
reports/
exports/
analysis_reports/
*.pdf

# ==========================================================
# Cache
# ==========================================================
.cache/
.cache-loader/
.eslintcache

# ==========================================================
# Archives
# ==========================================================
*.zip
*.tar
*.gz
*.rar
*.7z

# ==========================================================
# Local User Files
# ==========================================================
*.local
*.secret
*.key

# ==========================================================
# Runtime Files
# ==========================================================
*.pid
*.pid.lock

# ==========================================================
# Backup Files
# ==========================================================
*.orig
*.rej